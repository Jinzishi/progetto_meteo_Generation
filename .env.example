# Configurazione App Meteo
# Copia questo file in .env e modifica i valori

# URL API (default: Open-Meteo gratuito, senza chiave)
# METEO_GEOCODING_URL=https://geocoding-api.open-meteo.com/v1/search
# METEO_WEATHER_URL=https://api.open-meteo.com/v1/forecast

# API key (opzionale - Open-Meteo non la richiede)
# METEO_API_KEY=

# Timeout richieste HTTP in secondi (default: 10)
# METEO_REQUEST_TIMEOUT=10

# Durata cache in secondi (default: 3600 = 1 ora)
# METEO_CACHE_TTL=3600

# Salvataggio cache su disco per uso offline (true/false, default: true)
# METEO_CACHE_DISK=true

# Numero massimo citta' per richiesta batch (default: 10)
# METEO_MAX_CITIES=10
